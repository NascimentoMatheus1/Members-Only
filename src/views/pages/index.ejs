<!DOCTYPE html>
<html lang="en">

<%- include('../partials/head') %>

    <body>
        <%- include('../partials/navBar') %>
            <main>
                <div class="notice">
                    <% if (locals.currentUser && !currentUser.membership_status) { %>
                        <p><a href="/message/new">Create a new message</a></p>
                        <p>
                            <a href="/user/membership">Become a member</a> to view
                            authors of
                            posts.</a>
                        </p>
                        <% } else if (locals.currentUser && currentUser.membership_status) { %>
                            <p>Welcome back member</p>
                            <p><a href="/message/new">Create a new message</a></p>
                            <% } else { %>
                                <p>
                                    <a href="/user/login">Log in</a> or <a href="/user/sign-up">Sign up</a> to create
                                    posts and view
                                    authors.
                                </p>
                                <% }%>

                </div>
                <div class="posts-container">
                    <% if (locals.currentUser && currentUser.membership_status) { %>
                        <% posts.map( (post)=> { %>
                            <div class="message-card">
                                <div class="message-header">
                                    <div class="user-info">
                                        <span class="full-name">
                                            <%= post.first_name + post.last_name %>
                                        </span>
                                        <span class="username">@<%= post.username %></span>
                                        <span class="dot">•</span>
                                        <span class="created-at">
                                            <%= post.create_at %>
                                        </span>
                                    </div>
                                </div>

                                <div class="message-body">
                                    <h3 class="title">
                                        <%= post.title %>
                                    </h3>
                                    <p class="content">
                                        <%= post.content %>
                                    </p>
                                </div>
                                <%if(currentUser.isAdmin){%>
                                    <form action="/message/delete/<%= post.id %>" method="POST">
                                        <button type="submit" class="delete-btn" title="Delete"
                                            onclick="return confirm('Are you sure you want to delete this message?')">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6"></polyline>
                                                <path
                                                    d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2">
                                                </path>
                                            </svg>
                                        </button>
                                    </form>
                                    <%}%>
                            </div>


                            <% }) %>
                                <% } else { %>
                                    <% posts.map( (post)=> { %>
                                        <div class="message-card">
                                            <div class="message-header">
                                                <div class="user-info">
                                                    <span class="full-name">*** ********</span>
                                                    <span class="username">@***_***</span>
                                                    <span class="dot">•</span>
                                                    <span class="created-at">** ** **, ****</span>
                                                </div>
                                            </div>

                                            <div class="message-body">
                                                <h3 class="title">
                                                    <%= post.title %>
                                                </h3>
                                                <p class="content">
                                                    <%= post.content %>
                                                </p>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } %>
                </div>
            </main>
    </body>

</html>